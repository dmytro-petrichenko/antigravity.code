<article class="macro-widget">
    <h2 class="ds-text-section-title">@HeaderText</h2>

    <div class="stacked-bar ds-meter-track" role="img" aria-label="@BuildAriaLabel()">
        @foreach (var item in Sections)
        {
            <span class="bar-segment @MacroBarWidgetLogic.GetSegmentCssClass(item.Color)"
                  style="@MacroBarWidgetLogic.GetWidthStyle(item.Percentage)"></span>
        }
    </div>

    <ul class="legend-list ds-list-reset @LegendLayoutClass">
        @foreach (var item in _legendItems)
        {
            <li class="legend-item ds-legend-item ds-text-label">
                <span class="legend-swatch ds-swatch @MacroBarWidgetLogic.GetSwatchCssClass(item.Color)"
                      aria-hidden="true"></span>
                <span class="legend-text">@item.Label - @item.Amount</span>
            </li>
        }
    </ul>
</article>

@code {
    [Parameter, EditorRequired]
    public string HeaderText { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public IReadOnlyList<NutrientSegment> Sections { get; set; } = [];

    private IReadOnlyList<NutrientSegment> _legendItems = [];

    private string LegendLayoutClass => _legendItems.Count <= 2 ? "legend-list-few-items" : string.Empty;

    protected override void OnParametersSet()
    {
        MacroBarWidgetLogic.ValidateSections(Sections);
        _legendItems = Sections.Where(item => item.ShowInLegend).ToArray();
    }

    private string BuildAriaLabel()
    {
        var parts = _legendItems.Select(item => $"{item.Label} {item.Amount}");

        return $"{HeaderText}: {string.Join(", ", parts)}";
    }
}
