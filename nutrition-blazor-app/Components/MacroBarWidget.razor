<article class="macro-widget">
    <h2 class="macro-widget-title ds-text-section-title">@BuildHeaderText()</h2>

    <div class="stacked-bar ds-meter-track" role="img" aria-label="@BuildAriaLabel()">
        @for (var index = 0; index < Section.Components.Count; index++)
        {
            var item = Section.Components[index];
            var colorKey = MacroBarWidgetLogic.GetColorKey(index);

            <span class="bar-segment @MacroBarWidgetLogic.GetSegmentCssClass(colorKey)"
                  style="@MacroBarWidgetLogic.GetWidthStyle(item.PercentOfParent)"></span>
        }
    </div>

    <ul class="legend-list ds-list-reset @LegendLayoutClass">
        @for (var index = 0; index < _legendItems.Count; index++)
        {
            var item = _legendItems[index];
            var colorKey = MacroBarWidgetLogic.GetColorKey(index);

            <li class="legend-item ds-legend-item ds-text-label">
                <span class="legend-swatch ds-swatch @MacroBarWidgetLogic.GetSwatchCssClass(colorKey)"
                      aria-hidden="true"></span>
                <span class="legend-text">@item.Name - @FormatMeasuredValue(item.Amount)</span>
            </li>
        }
    </ul>
</article>

@code {
    [Parameter, EditorRequired]
    public NutritionDashboardDto.MacronutrientDetailsDto Section { get; set; } = new();

    private IReadOnlyList<NutritionDashboardDto.MacronutrientComponentDto> _legendItems = [];

    private string LegendLayoutClass => _legendItems.Count <= 2 ? "legend-list-few-items" : string.Empty;

    protected override void OnParametersSet()
    {
        MacroBarWidgetLogic.ValidateComponents(Section.Components);
        _legendItems = Section.Components;
    }

    private string BuildHeaderText()
        => $"{Section.MacronutrientName} - {FormatMeasuredValue(Section.TotalAmount)}";

    private string BuildAriaLabel()
    {
        var parts = _legendItems.Select(item => $"{item.Name} {FormatMeasuredValue(item.Amount)}");

        return $"{Section.MacronutrientName}: {string.Join(", ", parts)}";
    }

    private static string FormatMeasuredValue(NutritionDashboardDto.MeasuredValueDto value)
        => $"{value.Value.ToString("0.##", global::System.Globalization.CultureInfo.InvariantCulture)} {value.Unit}".Trim();
}
