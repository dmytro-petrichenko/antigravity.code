<section class="panel ds-card micronutrient-panel" aria-label="@Group.GroupName">
    @foreach (var item in Group.Items)
    {
        <article class="micro-item">
            <h2 class="micro-name ds-text-label">@item.NutrientName</h2>
            <p class="micro-meta ds-text-metric">@BuildMicroDetails(item)</p>
            <div class="micro-bar ds-meter-track" role="img" aria-label="@BuildMicroAriaLabel(item)">
                <span class="micro-fill" style="@GetWidthStyle(item.PercentDailyValue)"></span>
                <span class="micro-rest"></span>
            </div>
        </article>
    }
</section>

@code {
    [Parameter, EditorRequired]
    public NutritionDashboardDto.MicronutrientGroupDto Group { get; set; } = new();

    private static string GetWidthStyle(decimal percentage)
        => $"width: {percentage.ToString("0.##", global::System.Globalization.CultureInfo.InvariantCulture)}%;";

    private static string BuildMicroAriaLabel(NutritionDashboardDto.MicronutrientDto item)
        => $"{item.NutrientName}: {BuildMicroDetails(item)}";

    private static string BuildMicroDetails(NutritionDashboardDto.MicronutrientDto item)
        => $"{FormatMeasuredValue(item.Amount)} ({item.PercentDailyValue.ToString("0.##", global::System.Globalization.CultureInfo.InvariantCulture)}% DV)";

    private static string FormatMeasuredValue(NutritionDashboardDto.MeasuredValueDto value)
        => $"{value.Value.ToString("0.##", global::System.Globalization.CultureInfo.InvariantCulture)} {value.Unit}".Trim();
}
