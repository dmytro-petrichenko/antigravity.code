@page "/home"
@inject INutritionDataService NutritionDataService

<PageTitle>Nutrition Dashboard</PageTitle>

<main class="dashboard" aria-label="Nutrition dashboard">
    <h1 class="sr-only">Nutrition dashboard</h1>

    <NutritionFactsTestWidget ProductName="@ResolvedDashboard.Title" Calories="@ResolvedDashboard.Energy.Calories" />

    <section class="panel ds-card nutrition-panel" aria-label="Macronutrients">
        @foreach (var macroSection in ResolvedDashboard.MacronutrientDetails)
        {
            <MacroBarWidget Section="@macroSection" />
        }
    </section>

    <section class="panel ds-card macronutrient-pie-panel" aria-label="Macronutrient split">
        <MacronutrientPieWidget Slices="@ResolvedDashboard.Macronutrients.Distribution" />
    </section>

    <div class="dashboard-divider" aria-hidden="true"></div>

    <div class="micronutrient-row">
        <MicronutrientPanelWidget Group="@ResolvedDashboard.Vitamins" />
        <MicronutrientPanelWidget Group="@ResolvedDashboard.Minerals" />
    </div>
</main>

@code {
    [Parameter]
    public NutritionDashboardDto? Dashboard { get; set; }

    private NutritionDashboardDto ResolvedDashboard { get; set; } = new();

    protected override void OnParametersSet()
    {
        ResolvedDashboard = Dashboard ?? NutritionDataService.GetDashboard();
    }
}
